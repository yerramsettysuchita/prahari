# Copy to .env for local dev. On Cloud Run, set these as service env vars.

FIREBASE_PROJECT_ID=your-gcp-project-id
FIREBASE_STORAGE_BUCKET=your-gcp-project-id.appspot.com

# Local only: path to a service-account JSON with Firestore + Storage access.
# On Cloud Run this is unset — the attached service account is used instead.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json

# Gemini (wired in STEP 2+)
GOOGLE_API_KEY=your-gemini-api-key

# Escalation tuning (STEP 6). Set low for live demos.
SLA_HOURS=24
CITIZENS_THRESHOLD=5
THRESHOLD_WINDOW_HOURS=72

# BigQuery analytics (STEP 7). Optional: leave unset for the in-memory fallback.
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET=prahari
BIGQUERY_TABLE=cases
